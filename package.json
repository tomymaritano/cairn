{
  "name": "cairn",
  "version": "0.0.0",
  "private": true,
  "description": "The workflow engine for onboarding, product adoption, and user guidance.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "play": "pnpm --filter @cairn/playground dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm --filter \"./packages/*\" build && pnpm --filter \"./packages/*\" typecheck && pnpm --filter \"./packages/*\" test",
    "docs": "pnpm --filter @cairn/docs dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm verify && changeset publish",
    "clean": "pnpm -r clean",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@playwright/test": "^1.49.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0"
    }
  }
}
