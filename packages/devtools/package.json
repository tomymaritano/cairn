{
  "name": "@cairn/devtools",
  "version": "0.1.0",
  "description": "Visualize Cairn flows as a graph — static structure + live runtime trace.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@xyflow/react": "^12.3.0"
  },
  "peerDependencies": {
    "@cairn/core": "workspace:^",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@cairn/core": "workspace:^",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "keywords": ["cairn", "devtools", "flow", "graph", "visualizer", "react-flow"]
}
