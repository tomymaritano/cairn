{
  "name": "cairn-ui",
  "version": "0.2.0",
  "description": "Headless, accessible UI primitives for Cairn flows — spotlight & anchored popover.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.0"
  },
  "peerDependencies": {
    "cairn-react": "workspace:^",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "cairn-react": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "keywords": [
    "react",
    "onboarding",
    "popover",
    "spotlight",
    "headless",
    "accessible"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomymaritano/cairn.git",
    "directory": "packages/ui"
  },
  "homepage": "https://react-cairn.vercel.app",
  "bugs": {
    "url": "https://github.com/tomymaritano/cairn/issues"
  }
}
